 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 02 — Training Curves\n",
    "Visualize loss and metric curves from completed training runs.  \n",
    "Run after `outputs/checkpoints/baseline/` and `outputs/checkpoints/improved/` exist."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, sys\n",
    "from pathlib import Path\n",
    "\n",
    "repo_root = Path.cwd().parent\n",
    "os.chdir(repo_root)\n",
    "if str(repo_root) not in sys.path:\n",
    "    sys.path.insert(0, str(repo_root))\n",
    "\n",
    "from src.utils.paths import CHECKPOINTS_DIR\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "runs = {\"baseline\": CHECKPOINTS_DIR / \"baseline\",\n",
    "        \"improved\": CHECKPOINTS_DIR / \"improved\"}\n",
    "\n",
    "available = {k: v for k, v in runs.items() if (v / \"results.csv\").exists()}\n",
    "if not available:\n",
    "    print(\"No completed runs found. Train first with make train-baseline / make train-improved.\")\n",
    "else:\n",
    "    print(\"Found runs:\", list(available.keys()))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot training loss curves\n",
    "fig, axes = plt.subplots(1, len(available), figsize=(7 * len(available), 5))\n",
    "if len(available) == 1:\n",
    "    axes = [axes]\n",
    "\n",
    "for ax, (name, run_dir) in zip(axes, available.items()):\n",
    "    df = pd.read_csv(run_dir / \"results.csv\")\n",
    "    df.columns = df.columns.str.strip()\n",
    "    epoch = df[\"epoch\"]\n",
    "    for col in [\"train/box_loss\", \"train/cls_loss\", \"val/box_loss\", \"val/cls_loss\"]:\n",
    "        if col in df.columns:\n",
    "            ax.plot(epoch, df[col], label=col)\n",
    "    ax.set_title(name)\n",
    "    ax.set_xlabel(\"epoch\")\n",
    "    ax.set_ylabel(\"loss\")\n",
    "    ax.legend(fontsize=8)\n",
    "    ax.grid(True, alpha=0.3)\n",
    "\n",
    "plt.suptitle(\"Training & Validation Loss\", fontsize=13)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot mAP curves\n",
    "fig, axes = plt.subplots(1, len(available), figsize=(7 * len(available), 5))\n",
    "if len(available) == 1:\n",
    "    axes = [axes]\n",
    "\n",
    "for ax, (name, run_dir) in zip(axes, available.items()):\n",
    "    df = pd.read_csv(run_dir / \"results.csv\")\n",
    "    df.columns = df.columns.str.strip()\n",
    "    epoch = df[\"epoch\"]\n",
    "    for col in [\"metrics/mAP50(B)\", \"metrics/mAP50-95(B)\"]:\n",
    "        if col in df.columns:\n",
    "            ax.plot(epoch, df[col], label=col)\n",
    "    ax.set_title(name)\n",
    "    ax.set_xlabel(\"epoch\")\n",
    "    ax.set_ylabel(\"mAP\")\n",
    "    ax.set_ylim(0, 1)\n",
    "    ax.legend(fontsize=8)\n",
    "    ax.grid(True, alpha=0.3)\n",
    "\n",
    "plt.suptitle(\"Validation mAP\", fontsize=13)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Final epoch summary table\n",
    "rows = []\n",
    "for name, run_dir in available.items():\n",
    "    df = pd.read_csv(run_dir / \"results.csv\")\n",
    "    df.columns = df.columns.str.strip()\n",
    "    last = df.iloc[-1]\n",
    "    rows.append({\n",
    "        \"run\": name,\n",
    "        \"epochs\": int(last.get(\"epoch\", len(df))),\n",
    "        \"mAP@50\":    round(last.get(\"metrics/mAP50(B)\",    0), 4),\n",
    "        \"mAP@50:95\": round(last.get(\"metrics/mAP50-95(B)\", 0), 4),\n",
    "        \"precision\": round(last.get(\"metrics/precision(B)\", 0), 4),\n",
    "        \"recall\":    round(last.get(\"metrics/recall(B)\",    0), 4),\n",
    "    })\n",
    "\n",
    "pd.DataFrame(rows).set_index(\"run\")"
   ]
  }
 ],
